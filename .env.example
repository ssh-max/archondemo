# Required
ANTHROPIC_KEY=your-anthropic-api-key-here

# Optional — server port (default: 5000)
PORT=5000

# Optional — Claude model to use (default: claude-sonnet-4-6)
CLAUDE_MODEL=claude-sonnet-4-6

# Optional — CORS allowed origins, comma-separated (default: *)
# In production set this to your actual frontend domain e.g.:
# ALLOWED_ORIGINS=https://yourapp.com,https://www.yourapp.com
ALLOWED_ORIGINS=*

# Supabase persistence (backend only)
# SERVICE_KEY is a SECRET — backend-only, bypasses Row Level Security (RLS).
# Never expose it to the frontend or commit a real value.
SUPABASE_URL=
SUPABASE_SERVICE_KEY=

# Supabase JWT verification (backend only — never expose to frontend)
# SUPABASE_JWKS_URL: your project's JWKS endpoint.
#   Format: https://<project-ref>.supabase.co/auth/v1/.well-known/jwks.json
#   Find <project-ref>: Supabase Dashboard → Project Settings → General → Reference ID
SUPABASE_JWKS_URL=
# SUPABASE_JWT_ISSUER: the token issuer your project signs with.
#   Format: https://<project-ref>.supabase.co/auth/v1
#   Same Reference ID as above.
SUPABASE_JWT_ISSUER=
# SUPABASE_JWT_AUDIENCE: always "authenticated" for user-facing JWTs in Supabase.
#   Only change this if you have a custom audience configured in your project.
SUPABASE_JWT_AUDIENCE=authenticated
